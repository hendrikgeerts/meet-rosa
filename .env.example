# Copy to .env and fill in. Never commit .env.
#
# All non-secret runtime config lives in config/settings.yaml. .env holds
# only true secrets and per-installation identity (your phone number).

# Anthropic API key — get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Your iMessage identifier — the handle you message the agent FROM.
# Prefer phone number in E.164 format (e.g. +31612345678).
# Apple ID email also works as a fallback.
OWNER_IMESSAGE_HANDLE=

# Optional: additional accepted handles (comma-separated), e.g. your Apple ID
# email if you also message from there.
OWNER_EXTRA_HANDLES=

# HERE Maps API key — voor travel-time alerts (file-info + traffic-aware
# routing). Gratis tier 250K requests/maand. Aanmaken via
# https://platform.here.com/ → Projects → Create Project → REST → API Key.
HERE_API_KEY=

# ElevenLabs API key — voor neural TTS in voice-replies (engine='elevenlabs'
# in settings.yaml). Gratis tier 10K chars/maand. Aanmaken via
# https://elevenlabs.io/ → Profile → API Keys.
# Zonder key valt voice-reply automatisch terug op macOS `say`.
ELEVENLABS_API_KEY=

# Todoist API token — voor bidirectional sync van reminders + actionable
# open_loops naar Todoist. Aanmaken in de Todoist-app:
# Settings → Integrations → Developer → Copy API token.
# Zonder token wordt todoist-sync gewoon overgeslagen.
TODOIST_API_TOKEN=
